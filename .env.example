# Server-only OpenAI credential. Never prefix with NEXT_PUBLIC_ or commit a real value.
OPENAI_API_KEY=

# Server-side emergency switch for public AI endpoints.
AI_FEATURES_ENABLED=false

# Best-effort per-client limits for each warm server instance.
AI_RATE_LIMIT_WINDOW_SECONDS=600
AI_TRANSCRIBE_RATE_LIMIT=6
AI_PLAN_RATE_LIMIT=20

# Optional deployment metadata; contains no secret.
NEXT_PUBLIC_APP_ENV=development
